{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": false
  },
  "newProjectRoot": "projects",
  "projects": {
    "saf-formation": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              },
              {
                "glob": "**/*",
                "input": "src/assets",
                "output": "/assets"
              }
            ],
            "styles": [
              "src/styles.css",
              "src/assets/bootstrap/css/bootstrap.min.css",
              "src/assets/css/fonts.css",
              "src/assets/css/animate.css",
              "src/assets/css/slick.css",
              "src/assets/owlcarousel/css/owl.carousel.css",
              "src/assets/css/menu.css",
              "src/assets/css/style.css",
              "src/assets/css/responsive.css"
            ],
            "scripts": [
              "src/assets/js/jquery-1.12.4.min.js",
              "src/assets/bootstrap/js/bootstrap.min.js",
              "src/assets/js/modernizr-2.8.3.min.js",
              "src/assets/js/jquery.stellar.min.js",
              "src/assets/js/jquery.sticky.js",
              "src/assets/js/menu.js",
              "src/assets/owlcarousel/js/owl.carousel.min.js",
              "src/assets/js/jquery.magnific-popup.min.js",
              "src/assets/js/slick.min.js",
              "src/assets/js/jquery.mixitup.js",
              "src/assets/js/jquery.prettyPhoto.js",
              "src/assets/js/scrolltopcontrol.js",
              "src/assets/js/wow.min.js",
              "src/assets/js/scripts.js"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2MB",
                  "maximumError": "5MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "20kB",
                  "maximumError": "50kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "saf-formation:build:production"
            },
            "development": {
              "buildTarget": "saf-formation:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    }
  }
}